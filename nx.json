{
    "$schema": "./node_modules/nx/schemas/nx-schema.json",
    "defaultBase": "origin/main",
    "targetDefaults": {
        "composer-install": {
            "executor": "nx:run-commands",
            "options": {
                "command": "composer install",
                "cwd": "{projectRoot}"
            },
            "cache": true,
            "inputs": ["{projectRoot}/composer.json"],
            "outputs": ["{projectRoot}/vendor"]
        },
        "build": {
            "executor": "nx:run-commands",
            "options": {
                "command": "wp-scripts build",
                "cwd": "{projectRoot}",
                "output-path": "dist",
                "blocks-manifest": ""
            },
            "dependsOn": ["^build"],
            "cache": true,
            "inputs": ["{projectRoot}"],
            "outputs": ["{projectRoot}/dist"]
        },
        "start": {
            "executor": "nx:run-commands",
            "options": {
                "command": "wp-scripts start",
                "cwd": "{projectRoot}",
                "output-path": "dist",
                "blocks-manifest": ""
            },
            "dependsOn": ["^build"],
            "continuous": true,
            "inputs": ["{projectRoot}"],
            "outputs": ["{projectRoot}/dist"]
        },
        "test-integration": {
            "executor": "nx:run-commands",
            "options": {
                "command": "wp-env run tests-cli composer run test",
                "cwd": "{projectRoot}",
                "configuration": "vendor/wordpress-monorepo/phpunit-config/phpunit.integration.xml"
            },
            "dependsOn": ["composer-install", "wp-env-start"]
        },
        "test-e2e": {
            "executor": "nx:run-commands",
            "options": {
                "command": "wp-scripts test-playwright",
                "cwd": "{projectRoot}"
            },
            "dependsOn": ["^build", "wp-env-start"]
        },
        "test-screenshot": {
            "executor": "nx:run-commands",
            "options": {
                "command": "wp-scripts test-playwright",
                "cwd": "{projectRoot}",
                "config": "playwright.regression.config.js",
                "update-snapshots": "all"
            },
            "dependsOn": ["^build", "wp-env-start"]
        },
        "wp-env-start": {
            "executor": "nx:run-commands",
            "options": {
                "command": "wp-env start",
                "cwd": "{projectRoot}",
                "xdebug": "coverage"
            }
        },
        "wp-env-clean": {
            "executor": "nx:run-commands",
            "options": {
                "command": "wp-env clean",
                "cwd": "{projectRoot}"
            }
        }
    },
    "namedInputs": {
        "default": ["{projectRoot}/**/*", "sharedGlobals"],
        "sharedGlobals": []
    },
    "release": {
        "changelog": {
            "workspaceChangelog": {
                "createRelease": "github"
            }
        }
    },
    "analytics": true
}
