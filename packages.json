{
    "packages": {
        "bcgov-plugin/bcgov-wordpress-blocks": {
            "v1.0.0-alpha16": {
                "name": "bcgov-plugin/bcgov-wordpress-blocks",
                "description": "Plugin containing blocks intended to be used with the Design System WordPress Theme suite of products.",
                "type": "wordpress-plugin",
                "license": "Apache-2.0",
                "repositories": [
                    {
                        "type": "path",
                        "url": "../../packages/phpunit-config",
                        "options": {
                            "symlink": false
                        }
                    }
                ],
                "require-dev": {
                    "wordpress-monorepo/phpunit-config": "*",
                    "phpunit/phpunit": "^9.5"
                },
                "autoload": {
                    "psr-4": {
                        "Bcgov\\BcgovWordpressBlocks\\": "src/",
                        "Bcgov\\BcgovWordpressBlocks\\Test\\": "tests/php/"
                    }
                },
                "scripts": {
                    "test": [
                        "./vendor/bin/phpunit"
                    ]
                },
                "version": "1.0.0-alpha16",
                "dist": {
                    "url": "https://github.com/bcgov/wordpress-monorepo/releases/download/bcgov-wordpress-blocks/v1.0.0-alpha16/dist.zip",
                    "type": "zip"
                }
            }
        }
    }
}