{
    "name": "bcgov-wordpress-monorepo",
    "version": "0.0.1",
    "private": true,
    "description": "BC Government WordPress themes and plugins monorepo",
    "author": "govwordpress@gov.bc.ca",
    "license": "GPL-2.0-or-later",
    "keywords": [
        "bcgov",
        "wordpress",
        "monorepo",
        "plugins",
        "themes"
    ],
    "homepage": "https://github.com/bcgov/wordpress-monorepo",
    "repository": {
        "type": "git",
        "url": "https://github.com/bcgov/wordpress-monorepo"
    },
    "bugs": "https://github.com/bcgov/wordpress-monorepo/issues",
    "engines": {
        "node": "^24.12.0"
    },
    "workspaces": [
        "themes/*",
        "plugins/*",
        "packages/*"
    ],
    "dependencies": {
        "@fortawesome/fontawesome-free": "7.2.0",
        "@nx/devkit": "22.5.4",
        "@nx/plugin": "^22.6.2",
        "@playwright/test": "^1.58.2",
        "@swc-node/register": "~1.11.1",
        "@swc/cli": "~0.8.0",
        "@swc/core": "~1.15.21",
        "@swc/helpers": "~0.5.20",
        "@types/jest": "^30.0.0",
        "@types/node": "20.19.9",
        "@wordpress/block-editor": "15.17.0",
        "@wordpress/blocks": "15.17.0",
        "@wordpress/element": "6.44.0",
        "@wordpress/e2e-test-utils-playwright": "^1.42.0",
        "@wordpress/env": "^11.2.0",
        "@wordpress/i18n": "6.17.0",
        "@wordpress-monorepo/e2e": "workspace:*",
        "@wordpress/scripts": "^31.7.0",
        "@wordpress/stylelint-config": "^23.34.0",
        "eslint-plugin-playwright": "^2.10.1",
        "eslint-plugin-prefer-arrow": "^1.2.3",
        "js-beautify": "^1.15.4",
        "nx": "22.5.0",
        "prettier": "~3.6.2",
        "tslib": "^2.8.1",
        "typescript": "~5.9.3"
    },
    "scripts": {
        "composer-install": "npx nx run-many -t composer-install",
        "build": "npx nx run-many -t build",
        "start": "npx nx run-many -t start",
        "test-e2e": "npx nx run-many -t test-e2e",
        "test-integration": "npx nx run-many -t test-integration",
        "test-screenshot": "npx nx run-many -t test-screenshot",
        "test-unit-js": "npx nx run-many -t test-unit-js",
        "test-unit-php": "npx nx run-many -t test-unit-php",
        "lint": "pnpm run lint-js && pnpm run lint-css && pnpm run lint-php && pnpm run lint-md && pnpm run lint-pkg-json",
        "lint-js": "wp-scripts lint-js",
        "fix-js": "wp-scripts lint-js --fix",
        "lint-css": "wp-scripts lint-style",
        "fix-css": "wp-scripts lint-style --fix",
        "lint-php": "composer run lint-php",
        "fix-php": "composer run fix-php",
        "fix-html": "npx js-beautify --html {themes,plugins}/**/{parts,patterns,templates}/**/*",
        "lint-md": "wp-scripts lint-md-docs",
        "fix-md": "wp-scripts lint-md-docs --fix",
        "lint-pkg-json": "wp-scripts lint-pkg-json",
        "check-engines": "wp-scripts check-engines",
        "check-licenses": "wp-scripts check-licenses --prod",
        "wp-env": "wp-env",
        "wp-env-clean": "npx nx run-many -t wp-env-clean"
    }
}
