{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "bcgov-wordpress-blocks/icon",
    "version": "0.0.1",
    "title": "Icon",
    "category": "media",
    "icon": "images-alt",
    "description": "",
    "example": {},
    "attributes": {
        "iconId": {
            "type": "string",
            "default": ""
        },
        "iconSize": {
            "type": "string",
            "default": "medium"
        },
        "isDecorative": {
            "type": "boolean",
            "default": false
        },
        "accessibleName": {
            "type": "string",
            "default": ""
        }
    },
    "supports": {
        "html": false,
        "align": ["wide", "full"],
        "anchor": true,
        "color": {
            "text": true,
            "background": true,
            "gradients": false
        },
        "typography": {
            "fontSize": true
        },
        "spacing": {
            "padding": true,
            "margin": true
        }
    },
    "textdomain": "bcgov-wordpress-blocks",
    "editorScript": "file:./index.js",
    "editorStyle": "file:./index.css",
    "style": "file:./index.css"
}
